page {
  min-height: 100vh;
  background: #FFFDF2;
  color: #3A2A00;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", "Segoe UI", sans-serif;
}

view,
button,
text {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  color: inherit;
  line-height: 1;
}

button::after {
  border: 0;
}

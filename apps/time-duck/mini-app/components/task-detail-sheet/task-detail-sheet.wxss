.overlay {
  position: fixed;
  z-index: 38;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(122, 91, 0, 0.16);
}

.sheet {
  width: 100%;
  max-height: 78vh;
  padding: 10px 20px calc(24px + env(safe-area-inset-bottom));
  border-radius: 28px 28px 0 0;
  background: #FFFFFF;
  box-shadow: 0 -18px 44px rgba(122, 91, 0, 0.12);
}

.handle {
  width: 44px;
  height: 5px;
  margin: 0 auto 18px;
  border-radius: 999px;
  background: rgba(122, 91, 0, 0.16);
}

.title {
  color: #3A2A00;
  font-size: 22px;
  font-weight: 750;
  line-height: 1.35;
  overflow-wrap: anywhere;
}

.created {
  margin-top: 10px;
  color: #7A5B00;
  font-size: 13px;
  line-height: 1.45;
  overflow-wrap: anywhere;
}

.detail-grid {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 18px;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  min-height: 48px;
  padding: 14px;
  border-radius: 18px;
  background: #FFF7D3;
}

.key {
  color: #A57D00;
  font-size: 13px;
}

.value {
  min-width: 0;
  color: #3A2A00;
  font-size: 13px;
  text-align: right;
  overflow-wrap: anywhere;
}

.actions {
  display: flex;
  gap: 10px;
  margin-top: 18px;
}

.primary,
.secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  flex: 1;
  min-height: 52px;
  margin: 0;
  padding: 0 16px;
  border-radius: 18px;
  background: #FFD801;
  color: #3A2A00;
  font-size: 15px;
  font-weight: 800;
  line-height: 1;
  text-align: center;
}

.primary::after,
.secondary::after {
  border: 0;
}

.primary.warning {
  background: #ffb13b;
}

.secondary {
  background: #FFF7D3;
  color: #7A5B00;
}

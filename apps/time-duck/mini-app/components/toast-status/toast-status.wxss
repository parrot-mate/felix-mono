.toast {
  position: fixed;
  z-index: 60;
  top: 58px;
  left: 50%;
  max-width: 86vw;
  padding: 12px 16px;
  border-radius: 999px;
  background: #FFFFFF;
  color: #3A2A00;
  font-size: 13px;
  font-weight: 650;
  transform: translateX(-50%);
  box-shadow: 0 16px 40px rgba(122, 91, 0, 0.14);
}

.toast.success {
  color: #34c759;
}

.toast.warning {
  color: #7A5B00;
}

.toast.error {
  color: #ff5a5f;
}

.tabs {
  display: grid;
  grid-template-columns: 1fr 1.22fr 0.92fr;
  gap: 4px;
  margin: 18px 0 12px;
  padding: 6px;
  border-radius: 20px;
  background: rgba(255, 255, 255, 0.68);
  overflow: hidden;
  box-shadow: 0 10px 24px rgba(122, 91, 0, 0.07);
}

.tab::after {
  border: 0;
}

.tab {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-width: 0;
  height: 44px;
  margin: 0;
  padding: 0;
  border-radius: 16px;
  color: #7A5B00;
  font-size: 10px;
  font-weight: 650;
  line-height: 1;
  overflow: hidden;
  text-align: center;
  white-space: nowrap;
}

.tab.active {
  background: #FFD801;
  color: #3A2A00;
}

.voice-dock {
  position: fixed;
  right: 44px;
  bottom: calc(94px + env(safe-area-inset-bottom));
  left: 44px;
  z-index: 20;
}

.cancel-hint {
  width: 104px;
  margin: 0 auto 10px;
  padding: 8px 12px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.82);
  color: #7A5B00;
  font-size: 12px;
  font-weight: 700;
  text-align: center;
  box-shadow: 0 10px 24px rgba(122, 91, 0, 0.12);
}

.cancel-hint.active {
  background: #ffefe8;
  color: #d9480f;
}

.voice-button {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  min-height: 64px;
  margin: 0;
  padding: 0;
  border: 1px solid rgba(122, 91, 0, 0.12);
  border-radius: 24px;
  background: #FFD801;
  color: #3A2A00;
  font-size: 16px;
  font-weight: 800;
  box-shadow: 0 18px 44px rgba(122, 91, 0, 0.18);
}

.voice-button.failed {
  justify-content: center;
  gap: 10px;
  background: #FFD801;
  color: #3A2A00;
}

.voice-button.recognizing,
.voice-button.parsing,
.voice-button.setting_alarm {
  background: #FFFFFF;
  color: #3A2A00;
}

.voice-button.recording {
  justify-content: center;
  gap: 12px;
  padding: 10px;
  background: #FFFFFF;
}

.voice-button.recording.canceling {
  border-color: rgba(217, 72, 15, 0.28);
  background: #fff7f2;
}

.mic-dot {
  width: 12px;
  height: 12px;
  margin-right: 10px;
  border-radius: 999px;
  background: #FFD801;
}

.voice-button.failed .mic-dot {
  margin-right: 0;
  background: #3A2A00;
}

.mic-dot.error {
  background: #3A2A00;
}

.wave {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
  width: 92px;
  flex: 0 0 92px;
}

.recording-copy {
  min-width: 0;
}

.recording-title {
  color: #3A2A00;
  font-size: 15px;
  font-weight: 800;
  line-height: 1.2;
}

.recording-sub {
  margin-top: 4px;
  color: #7A5B00;
  font-size: 12px;
  line-height: 1.25;
}

.bar {
  width: 5px;
  border-radius: 999px;
  background: #FFD801;
  animation: wave 900ms ease-in-out infinite;
}

.b1 { height: 18px; }
.b2 { height: 30px; animation-delay: 80ms; }
.b3 { height: 42px; animation-delay: 160ms; }
.b4 { height: 28px; animation-delay: 240ms; }
.b5 { height: 20px; animation-delay: 320ms; }

@keyframes wave {
  0%, 100% { transform: scaleY(0.62); opacity: 0.62; }
  50% { transform: scaleY(1); opacity: 1; }
}

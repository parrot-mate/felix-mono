.item {
  display: flex;
  gap: 10px;
  min-height: 104px;
  padding: 16px;
  overflow: hidden;
  border: 1px solid rgba(122, 91, 0, 0.10);
  border-radius: 22px;
  background: #FFFFFF;
  box-shadow: 0 12px 28px rgba(122, 91, 0, 0.08);
}

.item.done {
  opacity: 0.58;
}

.main {
  min-width: 0;
  flex: 1;
}

.title {
  display: -webkit-box;
  overflow: hidden;
  color: #3A2A00;
  font-size: 16px;
  font-weight: 700;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 7px;
  color: #7A5B00;
  font-size: 13px;
  line-height: 1.35;
}

.repeat {
  color: #A57D00;
}

.spoken {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 8px;
  color: #A57D00;
  font-size: 12px;
  line-height: 1.4;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.side {
  display: flex;
  width: auto;
  min-width: 58px;
  flex: 0 0 auto;
  flex-direction: column;
  align-items: flex-end;
  justify-content: flex-start;
  gap: 12px;
  overflow: hidden;
}

.status {
  max-width: 76px;
  padding: 4px 8px;
  border-radius: 999px;
  background: #FFF6C9;
  color: #7A5B00;
  font-size: 11px;
  font-weight: 800;
  line-height: 1.3;
  text-align: right;
}

.pending_time .status {
  background: #FFF3DA;
  color: #A57D00;
}

.alarm_failed .status {
  background: #FFF0F0;
  color: #ff5a5f;
}

.small::after {
  border: 0;
}

.small {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 46px;
  min-width: 46px;
  height: 30px;
  margin: 0;
  padding: 0;
  border-radius: 12px;
  background: #FFD801;
  color: #3A2A00;
  font-size: 11px;
  font-weight: 800;
  line-height: 30px;
  overflow: hidden;
  text-align: center;
}

.small.warning {
  background: #FFD801;
}

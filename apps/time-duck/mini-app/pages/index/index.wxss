.page-shell {
  position: relative;
  min-height: 100vh;
  padding: 0 20px 184px;
  overflow-x: hidden;
  background:
    radial-gradient(circle at 50% -18%, rgba(255, 216, 1, 0.2), transparent 32%),
    linear-gradient(180deg, #FFFDF2 0%, #FFF9DF 52%, #FFFDF2 100%);
}

.status-space {
  height: 56px;
}

.hero {
  display: flex;
  align-items: center;
  margin-bottom: 18px;
}

.hero-left {
  display: flex;
  align-items: center;
  gap: 11px;
  min-width: 0;
}

.eyebrow {
  display: block;
  margin-bottom: 6px;
  color: #A57D00;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0;
}

.title {
  color: #3A2A00;
  font-size: 28px;
  font-weight: 750;
  line-height: 1.1;
}

.device-pill {
  display: inline-flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  gap: 6px;
  box-sizing: border-box;
  min-width: 0;
  height: 31px;
  margin: 0;
  padding: 0 10px;
  border: 1px solid rgba(122, 91, 0, 0.10);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.78);
  color: #7A5B00;
  font-size: 12px;
  font-weight: 800;
  line-height: 1;
}

.device-pill-label {
  display: inline-block;
  font-size: 12px;
}

.device-pill-label-wide {
  font-size: 13px;
  transform: none;
  transform-origin: center;
}

.device-pill::after {
  border: 0;
}

.device-pill.failed {
  color: #d9480f;
}

.device-pill.searching,
.device-pill.connecting {
  color: #A57D00;
}

.device-pill.connected {
  color: #237A3A;
}

.device-dot {
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: #B8B3A1;
}

.device-pill.failed .device-dot {
  background: #ff5a5f;
}

.device-pill.searching .device-dot,
.device-pill.connecting .device-dot {
  background: #FFD801;
}

.device-pill.connected .device-dot {
  background: #36D665;
}

.voice-page,
.list-page {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.voice-hero-card,
.recent-card {
  border: 1px solid rgba(122, 91, 0, 0.10);
  border-radius: 24px;
  background: #FFFFFF;
  box-shadow: 0 14px 34px rgba(122, 91, 0, 0.08);
}

.voice-hero-card {
  position: relative;
  min-height: 176px;
  padding: 24px;
  overflow: hidden;
}

.voice-hero-card::after {
  content: "";
  position: absolute;
  right: -20px;
  bottom: -34px;
  width: 138px;
  height: 138px;
  border-radius: 50%;
  background: #FFD801;
  opacity: 0.92;
}

.voice-kicker {
  position: relative;
  z-index: 1;
  color: #A57D00;
  font-size: 12px;
  font-weight: 800;
}

.voice-heading {
  position: relative;
  z-index: 1;
  width: 74%;
  margin-top: 12px;
  color: #3A2A00;
  font-size: 28px;
  font-weight: 850;
  line-height: 1.18;
}

.voice-copy {
  position: relative;
  z-index: 1;
  width: 68%;
  margin-top: 12px;
  color: #7A5B00;
  font-size: 14px;
  line-height: 1.55;
}

.recent-card {
  padding: 16px;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4px 2px 0;
}

.section-title {
  color: #3A2A00;
  font-size: 16px;
  font-weight: 850;
}

.section-sub {
  margin-top: 5px;
  color: #A57D00;
  font-size: 12px;
}

.bottom-tabs {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 30;
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: calc(64px + env(safe-area-inset-bottom));
  padding: 6px 18px calc(6px + env(safe-area-inset-bottom));
  border-top: 1px solid rgba(122, 91, 0, 0.10);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8px 28px rgba(122, 91, 0, 0.10);
}

.bottom-tab {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 4px;
  height: 58px;
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  color: #B8B3A1;
  font-size: 12px;
  font-weight: 800;
  line-height: 1;
}

.bottom-tab::after {
  border: 0;
}

.bottom-tab.active {
  color: #A57D00;
}

.tab-icon {
  position: relative;
  box-sizing: border-box;
  width: 25px;
  height: 25px;
  color: #B8B3A1;
}

.bottom-tab.active .tab-icon {
  color: #A57D00;
}

.tab-clock {
  border: 2px solid currentColor;
  border-radius: 50%;
}

.tab-clock::before,
.tab-clock::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  border-radius: 999px;
  background: currentColor;
  transform-origin: left center;
}

.tab-clock::before {
  width: 7px;
  height: 2px;
  transform: translate(-1px, -1px) rotate(0deg);
}

.tab-clock::after {
  width: 2px;
  height: 8px;
  transform: translate(-1px, -7px);
}

.tab-list {
  border: 2px solid currentColor;
  border-radius: 7px;
}

.tab-list::before,
.tab-list::after {
  content: "";
  position: absolute;
  left: 6px;
  right: 6px;
  height: 2px;
  border-radius: 999px;
  background: currentColor;
}

.tab-list::before {
  top: 8px;
}

.tab-list::after {
  bottom: 8px;
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "types": ["./types/wx"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "app.ts",
    "pages/**/*.ts",
    "components/**/*.ts",
    "models/**/*.ts",
    "services/**/*.ts",
    "utils/**/*.ts",
    "types/**/*.d.ts"
  ]
}

{
  "name": "@pmate/service",
  "scripts": {
    "serve:signal": "npm run build && pm2 start ./dist/room/room.io.js",
    "build": "tsc",
    "serve:wshub1": "PORT=8020 pm2 start ./dist/entry/wshub.js --name 'wshub1'",
    "serve:wshub2": "PORT=8021 pm2 start ./dist/entry/wshub.js --name 'wshub2'",
    "serve:ci": "PORT=9103 pm2 start ./dist/entry/ci.server.js --name 'ci'",
    "serve:cms": "PORT=9105 pm2 start ./dist/entry/cms.server.js --name 'cms'",
    "serve:log-qa": "PORT=9104 pm2 start ./dist/entry/log.server.js --name 'log-qa'",
    "serve:sig": "pm2 start ./dist/entry/room.socket.js --name 'sig'",
    "serve:gpt": "pm2 start 'proxychains4 node ./dist/entry/runner.js \"@gpt#1\"' --name gpt",
    "serve:imgen": "pm2 start 'proxychains4 node ./dist/entry/runner.js \"@imgen#1\"' --name imgen",
    "tsdb:refresh": "npm run build && node ./dist/tool/refreshTSDBConfig.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@alicloud/pop-core": "^1.8.0",
    "@aws-sdk/client-s3": "^3.515.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google-cloud/text-to-speech": "^5.5.0",
    "@msgpack/msgpack": "^3.1.2",
    "@pmate/utils": "workspace:*",
    "@pmate/meta": "workspace:*",
    "@pmate/sdk": "workspace:*",
    "@pmate/proxy": "workspace:*",
    "@pmate/service-core": "workspace:*",
    "@pmate/service-utils": "workspace:*",
    "@pmate/blockchain": "workspace:*",
    "@types/chalk": "^2.2.0",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.0",
    "@types/sax": "^1.2.7",
    "@types/ws": "^8.5.13",
    "@volcengine/openapi": "^1.30.1",
    "ali-oss": "^6.20.0",
    "alibabacloud-nls": "^1.0.4",
    "axios": "catalog:",
    "chalk": "^4.1.2",
    "chardet": "^2.1.0",
    "cheerio": "1.0.0-rc.12",
    "dotenv": "catalog:",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.2",
    "fs-extra": "^11.2.0",
    "htmlparser2": "^10.0.0",
    "iconv-lite": "^0.6.3",
    "lodash": "^4.17.21",
    "microsoft-cognitiveservices-speech-sdk": "^1.41.0",
    "natural": "^6.10.5",
    "node-fetch": "^1.7.3",
    "nodemailer": "^7.0.3",
    "openai": "^4.93.0",
    "sax": "^1.4.1",
    "sentencex": "^0.4.2",
    "sharp": "^0.33.2",
    "socket.io": "^4.8.1",
    "tiktoken": "^1.0.14",
    "uuid": "^11.0.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.16.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node-fetch": "^1.6.9",
    "@types/nodemailer": "^6.4.17",
    "cors": "^2.8.5",
    "nodemon": "^3.0.3",
    "vitest": "^1.0.0"
  }
}

{
  "name": "@pmate/account-sdk",
  "version": "0.5.5",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && rollup -c rollup.config.dts.ts",
    "npm:publish": "pnpm build && npm publish --registry https://registry.npmjs.org/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "jotai": "*",
    "jotai-family": "*",
    "react": "*"
  },
  "dependencies": {
    "browser-image-compression": "^2.0.2",
    "i18next": "^23.0.0",
    "react-i18next": "^13.0.0",
    "react-use": "^17.6.0"
  },
  "devDependencies": {
    "@pmate/utils": "workspace:*",
    "@pmate/lang": "workspace:*",
    "@pmate/meta": "workspace:*",
    "@types/react": "*",
    "@types/react-dom": "*",
    "@vitejs/plugin-react": "^4.2.1",
    "jsdom": "^26.1.0",
    "react-dom": "*",
    "rollup": "^4.21.2",
    "rollup-plugin-dts": "^6.1.1",
    "typescript": "^5.2.2",
    "vite": "catalog:",
    "vitest": "^4.0.17"
  }
}
